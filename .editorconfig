root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[Makefile]
indent_style = tab

[*.py]
indent_style = space
indent_size = 4

[*.{css,scss,xml,svg,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 4

[*.fish]
indent_style = space
indent_size = 4

[PKGBUILD]
indent_style = space
indent_size = 4
