       EDITOR CHROME - UI Elements
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Base Editor -->
  <style name="text"                      foreground="fg-primary" background="bg-base"/>
  <style name="cursor"                    foreground="fg-bright"/>
  <style name="selection"                 background="bg-selection"/>
  <style name="selection-unfocused"       background="bg-overlay"/>
  <style name="current-line"              background="bg-highlight"/>
  <style name="current-line-number"       foreground="teal" background="bg-highlight" bold="true"/>
  <style name="line-numbers"              foreground="fg-faint" background="bg-base"/>
  <style name="line-numbers-border"       foreground="fg-invisible" background="bg-surface"/>

  <!-- Whitespace and Guides -->
  <style name="draw-spaces"               foreground="fg-invisible"/>
  <style name="right-margin"              foreground="fg-invisible" background="bg-surface"/>
  <style name="background-pattern"        background="#rgba(68,71,90,0.08)"/>

  <!-- Search and Matching -->
  <style name="search-match"              foreground="bg-void" background="yellow" bold="true"/>
  <style name="quick-highlight-match"     background="#rgba(249,226,175,0.25)"/>
  <style name="bracket-match"             foreground="fg-bright" background="mauve" bold="true"/>
  <style name="bracket-mismatch"          foreground="fg-bright" background="red" bold="true" underline="error"/>

  <!-- Snippets -->
  <style name="snippet-focus"             foreground="fg-bright" background="bg-active"/>

