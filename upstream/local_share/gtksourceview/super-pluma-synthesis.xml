<?xml version="1.0" encoding="UTF-8"?>
<!--
  Super-Pluma Synthesis - Premium Color Scheme for GtkSourceView
  ==============================================================

  A meticulously crafted color scheme synthesizing:
  - Dracula: Rich dark backgrounds, high-contrast accents
  - Catppuccin Mocha: Warm pastels, comfortable extended reading
  - CachyOS Teal: System identity accent (#17b169)
  - Paul Tol: Colorblind-safe palette principles
  - Semantic Typography: Bold keywords, italic comments, underlined links

  Design Principles:
  1. WCAG AAA contrast ratios for primary text
  2. Semantic color groupings (warm=values, cool=types, bold=control)
  3. Reduced cognitive load via consistent visual language
  4. Colorblind accessibility (no red-green-only distinctions)
  5. Extended language support with nuanced per-element styling

  Installation:
    ~/.local/share/gtksourceview-4/styles/
    ~/.local/share/gtksourceview-3/styles/

  Part of Super-Pluma: Memory-optimized Pluma plugin distribution
  License: GPL-3.0-or-later
-->
<style-scheme id="super-pluma-synthesis" _name="Super-Pluma Synthesis" version="1.0" kind="dark">
  <author>Super-Pluma Project</author>
  <_description>Premium dark theme: Dracula + Catppuccin + CachyOS synthesis with full language support</_description>

  <!-- ═══════════════════════════════════════════════════════════════════
       CORE PALETTE - Foundational Colors
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Background Hierarchy (darkest to lightest) -->
  <color name="bg-void"         value="#1a1b26"/>  <!-- Deepest: popups, tooltips -->
  <color name="bg-base"         value="#232530"/>  <!-- Primary editor background -->
  <color name="bg-surface"      value="#2a2c3a"/>  <!-- Cards, panels -->
  <color name="bg-elevated"     value="#2d2f3d"/>  <!-- Raised elements -->
  <color name="bg-overlay"      value="#313347"/>  <!-- Overlays, modals -->
  <color name="bg-highlight"    value="#383a4a"/>  <!-- Current line -->
  <color name="bg-selection"    value="#44475a"/>  <!-- Selection (Dracula) -->
  <color name="bg-hover"        value="#4a4d5e"/>  <!-- Hover states -->
  <color name="bg-active"       value="#525569"/>  <!-- Active/pressed -->

  <!-- Foreground Hierarchy (brightest to dimmest) -->
  <color name="fg-bright"       value="#ffffff"/>  <!-- Maximum contrast -->
  <color name="fg-primary"      value="#f4f4f5"/>  <!-- Main text (WCAG AAA) -->
  <color name="fg-secondary"    value="#cdd6f4"/>  <!-- Catppuccin text -->
  <color name="fg-tertiary"     value="#bac2de"/>  <!-- Subtext1 -->
  <color name="fg-muted"        value="#9399b2"/>  <!-- Comments, disabled -->
  <color name="fg-subtle"       value="#7f849c"/>  <!-- Overlay1 -->
  <color name="fg-faint"        value="#6c7086"/>  <!-- Overlay0 -->
  <color name="fg-invisible"    value="#585b70"/>  <!-- Whitespace, guides -->

  <!-- ═══════════════════════════════════════════════════════════════════
       ACCENT PALETTE - Semantic Colors (Colorblind-Safe)
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Primary Accents -->
  <color name="teal"            value="#17b169"/>  <!-- CachyOS identity -->
  <color name="teal-dim"        value="#14996b"/>  <!-- Teal variant -->
  <color name="teal-bright"     value="#1cc97a"/>  <!-- Teal highlight -->

  <!-- Cool Spectrum (Types, Structure) -->
  <color name="cyan"            value="#89dceb"/>  <!-- Sky -->
  <color name="cyan-dim"        value="#74c7ec"/>  <!-- Sapphire -->
  <color name="cyan-bright"     value="#94e2f2"/>  <!-- Sky bright -->
  <color name="blue"            value="#89b4fa"/>  <!-- Blue -->
  <color name="blue-dim"        value="#7ba3e8"/>  <!-- Blue muted -->
  <color name="blue-bright"     value="#a6c8ff"/>  <!-- Blue highlight -->
  <color name="lavender"        value="#b4befe"/>  <!-- Lavender -->

  <!-- Warm Spectrum (Values, Literals) -->
  <color name="yellow"          value="#f9e2af"/>  <!-- Yellow -->
  <color name="yellow-dim"      value="#e8d19e"/>  <!-- Yellow muted -->
  <color name="yellow-bright"   value="#fff3c4"/>  <!-- Yellow highlight -->
  <color name="peach"           value="#fab387"/>  <!-- Peach -->
  <color name="peach-dim"       value="#e9a276"/>  <!-- Peach muted -->
  <color name="peach-bright"    value="#ffbe98"/>  <!-- Peach highlight -->
  <color name="flamingo"        value="#f2cdcd"/>  <!-- Flamingo -->

  <!-- Purple Spectrum (Keywords, Control Flow) -->
  <color name="mauve"           value="#cba6f7"/>  <!-- Mauve (primary keyword) -->
  <color name="mauve-dim"       value="#b995e6"/>  <!-- Mauve muted -->
  <color name="mauve-bright"    value="#ddb7ff"/>  <!-- Mauve highlight -->
  <color name="violet"          value="#b4befe"/>  <!-- Lavender -->

  <!-- Pink Spectrum (Operators, Special) -->
  <color name="pink"            value="#f5c2e7"/>  <!-- Pink -->
  <color name="pink-dim"        value="#e4b1d6"/>  <!-- Pink muted -->
  <color name="pink-bright"     value="#ffd3f8"/>  <!-- Pink highlight -->
  <color name="maroon"          value="#eba0ac"/>  <!-- Maroon -->

  <!-- Status Colors -->
  <color name="green"           value="#a6e3a1"/>  <!-- Success, additions -->
  <color name="green-dim"       value="#95d290"/>  <!-- Green muted -->
  <color name="green-bright"    value="#b7f4b2"/>  <!-- Green highlight -->
  <color name="red"             value="#f38ba8"/>  <!-- Error, deletions -->
  <color name="red-dim"         value="#e27a97"/>  <!-- Red muted -->
  <color name="red-bright"      value="#ff9cb9"/>  <!-- Red highlight -->
  <color name="orange"          value="#fab387"/>  <!-- Warning -->

  <!-- Rainbow Brackets (6-color cycle) -->
  <color name="rainbow-1"       value="#f38ba8"/>  <!-- Red/Maroon -->
  <color name="rainbow-2"       value="#fab387"/>  <!-- Peach -->
  <color name="rainbow-3"       value="#f9e2af"/>  <!-- Yellow -->
  <color name="rainbow-4"       value="#a6e3a1"/>  <!-- Green -->
  <color name="rainbow-5"       value="#89b4fa"/>  <!-- Blue -->
  <color name="rainbow-6"       value="#cba6f7"/>  <!-- Mauve -->

