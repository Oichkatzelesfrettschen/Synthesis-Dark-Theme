  <style name="def:note"                  foreground="yellow" background="bg-elevated" bold="true"/>
  <style name="def:attention"             foreground="orange" background="bg-elevated" bold="true"/>

  <!-- === KEYWORDS (Purple + Bold - Control Flow, Important) === -->
