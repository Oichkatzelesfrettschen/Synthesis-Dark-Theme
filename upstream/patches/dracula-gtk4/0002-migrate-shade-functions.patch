--- a/gtk-4.0/gtk.css
+++ b/gtk-4.0/gtk.css
@@ -53,11 +53,20 @@
 /* Window Decorations */
 /* ==================== */
 
-@define-color wm_title shade(#f8f8f2, 1.8);
-@define-color wm_bg shade(#1e1f29, 0.8);
-@define-color wm_bg_a shade(#1e1f29, 1.2);
-@define-color wm_button_hover_color_a shade(#1e1f29, 1.3);
-@define-color wm_shadow alpha(black, 0.35);
+/* GTK4 Compatible: Using color-mix() instead of deprecated shade() and alpha() */
+/* shade(#f8f8f2, 1.8) - lighter by 80% */
+@define-color wm_title color-mix(in srgb, #f8f8f2 0%, white 40%);
+/* shade(#1e1f29, 0.8) - darker by 20% */
+@define-color wm_bg color-mix(in srgb, #1e1f29 0%, black 10%);
+/* shade(#1e1f29, 1.2) - lighter by 20% */
+@define-color wm_bg_a color-mix(in srgb, #1e1f29 0%, white 10%);
+/* shade(#1e1f29, 1.3) - lighter by 30% */
+@define-color wm_button_hover_color_a color-mix(in srgb, #1e1f29 0%, white 15%);
+/* alpha(black, 0.35) - 35% opacity black */
+@define-color wm_shadow color-mix(in srgb, black 35%, transparent);
 @define-color wm_border alpha(black, 0.18);
 @define-color wm_border_unfocused alpha(black, 0.12);
 @define-color wm_button_hover_color shade(#1e1f29, 1.2);
